MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: local - Cinem_Inicio_es
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: es
  m_SharedData: {fileID: 11400000, guid: 260527095793c594ea50eb723a681409, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 21240901632
    m_Localized: "Mira esas estrellas, Paco. Ojal\xE1 las luci\xE9rnagas fueran as\xED
      de grandes... no tendr\xEDamos que trabajar en un mes"
    m_Metadata:
      m_Items: []
  - m_Id: 21261873152
    m_Localized: "T\xFA nunca has trabajado un mes seguido en tu vida, Pepe. Deja
      de mirar las luces y disfruta del fresco"
    m_Metadata:
      m_Items: []
  - m_Id: 21261873153
    m_Localized: Mira eso... Es la madre de todas las moscas. Es... es gloriosa
    m_Metadata:
      m_Items: []
  - m_Id: 21261873154
    m_Localized: "Ni se te ocurra. Esa cosa tiene el tama\xF1o de un zapato viejo.
      Vas a reventar como un globo"
    m_Metadata:
      m_Items: []
  - m_Id: 21261873155
    m_Localized: "Solo se vive una vez, socio. \xA1Buen provecho!"
    m_Metadata:
      m_Items: []
  - m_Id: 21261873156
    m_Localized: "\xA1THWIP! \xA1CHOMP! \xA1GLUP!"
    m_Metadata:
      m_Items: []
  - m_Id: 21261873157
    m_Localized: "\xA1Cof! \xA1Cof! Vale... mmm... creo que... \xA1cof!... est\xE1
      intentando salir..."
    m_Metadata:
      m_Items: []
  - m_Id: 21261873158
    m_Localized: "Te lo dije. Dale un golpe al pecho, ya ver\xE1s como sale disparada"
    m_Metadata:
      m_Items: []
  - m_Id: 21261873159
    m_Localized: "\xA1No puedo... cof... no hay aire! \xA1Paco! \xA1S\xE1came esta
      bestia de la garganta!"
    m_Metadata:
      m_Items: []
  - m_Id: 21261873160
    m_Localized: "\xA1\xBFPepe?! \xA1Eh, no me bromees con esto! \xA1Escupe ese bicho
      ahora mismo!"
    m_Metadata:
      m_Items: []
  - m_Id: 21261873161
    m_Localized: "(Silencio absoluto en el pantano. Pepe se desploma hacia atr\xE1s
      sobre la hoja)"
    m_Metadata:
      m_Items: []
  - m_Id: 21261873162
    m_Localized: "\xBFPepe? Venga ya... lev\xE1ntate. No puedes morir por una mosca,
      ser\xEDa la muerte m\xE1s tonta del condado"
    m_Metadata:
      m_Items: []
  - m_Id: 21261873163
    m_Localized: "\xBFPero qu\xE9...? \xA1Pepe! \xA1Vuelve aqu\xED! \xA1Tu cuerpo
      se ha quedado aqu\xED abajo!"
    m_Metadata:
      m_Items: []
  - m_Id: 21261873164
    m_Localized: "\xA1Cielos! \xA1Paco, estoy brillando! \xA1Y estoy flotando! \xA1Esto
      no es lo que yo quer\xEDa!"
    m_Metadata:
      m_Items: []
  - m_Id: 21261873165
    m_Localized: "Si piensas que te vas a ir al Cielo a comer nubes mientras yo me
      quedo aqu\xED solo... vas listo"
    m_Metadata:
      m_Items: []
  - m_Id: 21261873166
    m_Localized: Toda la vida practicando saltos para nada. Pepe, que voy por ti!
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
