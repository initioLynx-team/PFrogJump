  m_TableData:
  - m_Id: 31865638912
    m_Localized: "\xBFPaco?"
    m_Metadata:
      m_Items: []
  - m_Id: 70235131904
    m_Localized: "\xA1Pepe! \xA1\xA1He llegado!!"
    m_Metadata:
      m_Items: []
  - m_Id: 95027662848
    m_Localized: Mmm....creo que no...
    m_Metadata:
      m_Items: []
  - m_Id: 210308108288
    m_Localized: "\xBFC\xF3mo? Si arriba pon\xEDa que estabas aqu\xED..."
    m_Metadata:
      m_Items: []
  - m_Id: 257976373248
    m_Localized: Me temo que esto es solo el comienzo...
    m_Metadata:
      m_Items: []
  - m_Id: 326024761344
    m_Localized: "A\xFAn te quedan los manglares..."
    m_Metadata:
      m_Items: []
  - m_Id: 370543104000
    m_Localized: ...las oscuras y tenebrosas cuevas....
    m_Metadata:
      m_Items: []
  - m_Id: 408820322304
    m_Localized: ...la dura tormenta...
    m_Metadata:
      m_Items: []
  - m_Id: 449177915392
    m_Localized: ...antes de llegar al cielo...
    m_Metadata:
      m_Items: []
  - m_Id: 521961672704
    m_Localized: "\xA1\xA1\xA1\xA1OMG!!!!"
    m_Metadata:
      m_Items: []
